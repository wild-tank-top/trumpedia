generator client {
  provider = "prisma-client-js"
}

datasource db {
provider = "postgresql"
url      = env("DATABASE_URL")
}

// ── NextAuth 必須モデル ─────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?           // Credentials認証用（ハッシュ済み）
  role          String    @default("guest") // guest / fellow / admin
  createdAt     DateTime  @default(now())

  accounts           Account[]
  sessions           Session[]
  answers            Answer[]
  profile            Profile?
  questions          Question[]
  likes              Like[]
  notifications      Notification[]
  issuedInviteCodes  InviteCode[]        @relation("IssuedInviteCodes")
  usedInviteCode     InviteCode?         @relation("UsedInviteCode")
  fellowApplication  FellowApplication?  @relation("FellowApplications")
  fellowReferrals    FellowApplication[] @relation("FellowReferrals")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── アプリモデル ────────────────────────────────────

model Profile {
  id        Int    @id @default(autoincrement())
  userId    String @unique
  yomi      String @default("")  // 名前のよみ（ひらがな）— 50音順ソート・フィルタに使用
  bio       String @default("")
  career    String @default("")
  twitter   String @default("")
  youtube   String @default("")
  instagram String @default("")
  website   String @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Question {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   // 詳細・補足（質問の意図・背景）
  category  String
  level     String
  status    String   @default("pending") // pending / approved / rejected
  views          Int      @default(0)         // 閲覧数（imp）
  thumbnail      String?                      // AIサムネイル画像URL
  userId         String?  // 投稿者ID
  createdAt      DateTime @default(now())
  lastAnsweredAt DateTime?                    // 最新回答日（ソート用・非正規化）

  answers       Answer[]
  supplements   QuestionSupplement[]
  notifications Notification[]
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([status, createdAt(sort: Desc)])
  @@index([userId])
}

model Answer {
  id            Int      @id @default(autoincrement())
  questionId    Int
  userId        String
  summary       String
  causeAnalysis String
  thinking      String
  approach      String
  ngExamples    String
  exceptions    String
  philosophy    String
  createdAt     DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    Like[]

  @@index([questionId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model Like {
  id        Int      @id @default(autoincrement())
  userId    String
  answerId  Int
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@unique([userId, answerId])
  @@index([answerId])
}

model QuestionSupplement {
  id         Int      @id @default(autoincrement())
  questionId Int
  content    String
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     String
  questionId Int
  type       String   @default("supplement")
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId, type])
  @@index([userId, isRead])
}

// ── Fellowsネットワーク ─────────────────────────────

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  issuerId  String
  issuer    User      @relation("IssuedInviteCodes", fields: [issuerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  usedById  String?   @unique
  usedBy    User?     @relation("UsedInviteCode", fields: [usedById], references: [id], onDelete: SetNull)
  application FellowApplication?
  createdAt DateTime  @default(now())
}

model FellowApplication {
  id           String    @id @default(cuid())
  applicantId  String    @unique
  applicant    User      @relation("FellowApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  referrerId   String
  referrer     User      @relation("FellowReferrals", fields: [referrerId], references: [id])
  inviteCodeId String    @unique
  inviteCode   InviteCode @relation(fields: [inviteCodeId], references: [id])
  status       String    @default("pending")
  // pending → referrer_approved → admin_completed
  referrerNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([referrerId, status])
  @@index([status])
}


// ── アクセス解析 ──────────────────────────────────────

model PageView {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}
